businessService:hasSequenceNumber rdf:type owl:DatatypeProperty ;
                                  rdfs:domain businessService:BusinessTransactionAAAA ;
                                  rdfs:range xsd:string ;
                                  rdfs:comment "The relationship between the business transaction and its sequence number expressed as a string" ;
                                  rdfs:label "Has Sequence Number" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#itineraryID
businessService:itineraryID rdf:type owl:DatatypeProperty ;
                            rdfs:domain businessService:Itinerary ;
                            rdfs:range xsd:string ;
                            rdfs:comment "Each itinerary is assigned an unique ID" ;
                            rdfs:label "Itinerary ID" ;
                            skos:altLabel "voyageID" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#serviceName
businessService:serviceName rdf:type owl:DatatypeProperty ;
                            rdfs:domain businessService:LogisticsService ;
                            rdfs:range xsd:string ;
                            rdfs:comment "Each type of logistics service can be described using a name." ;
                            rdfs:label "Service name" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#transportPlanIssuanceTime
businessService:transportPlanIssuanceTime rdf:type owl:DatatypeProperty ;
                                          rdfs:domain businessService:BusinessTransactionAAAA ;
