@base <https://ontology.tno.nl/logistics/federated/BusinessService> .

<https://ontology.tno.nl/logistics/federated/BusinessService> rdf:type owl:Ontology ;
                                                               dc:creator "Dena Tahvildari, Maaike Burghoorn, Cornelis Bouter" ;
                                                               dcterms:created "2020-07-20" ;
                                                               dcterms:description "This ontology contains classes, attributes, relation about business services that are used in Logistics events." ;
                                                               dcterms:isRequiredBy <https://ontology.tno.nl/logistics/federated/Event> ;
                                                               dcterms:issued "2021-03-15" ;
                                                               dcterms:language "en" ;
                                                               dcterms:requires <https://ontology.tno.nl/logistics/federated/Classifications> ,
                                                                                <https://ontology.tno.nl/logistics/federated/LogisticsRoles> ;
                                                               owl:versionInfo "Created with TopBraid Composer" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/created
dcterms:created rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
dcterms:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/isRequiredBy
dcterms:isRequiredBy rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/issued
dcterms:issued rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/language
dcterms:language rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/requires
dcterms:requires rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .


###  https://ontology.tno.nl/logistics/federated/ReusableTags#isDerived
ReusableTags:isDerived rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://ontology.tno.nl/logistics/federated/BusinessService#actorAddress
businessService:actorAddress rdf:type owl:ObjectProperty ;
                             rdfs:domain businessService:LegalPerson ;
                             rdfs:range <https://schema.org/Place> ;
                             rdfs:comment "Address of the logistics actor" ;
                             rdfs:label "Actor address" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#actorRoleCode
businessService:actorRoleCode rdf:type owl:ObjectProperty ;
                              rdfs:domain businessService:LegalPerson ;
                              rdfs:range Classifications:Classifications ;
                              rdfs:comment "The code of the role played by the legal person, such as the sealing party role code)." ;
                              rdfs:label "Actor Role Code" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#hasBookingStatus
businessService:hasBookingStatus rdf:type owl:ObjectProperty ;
                                 rdfs:domain businessService:Booking ;
                                 rdfs:range businessService:BookingStatus ;
                                 rdfs:comment "The relationship between booking and booking status" ;
                                 rdfs:label "Booking Status" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#hasLocation
businessService:hasLocation rdf:type owl:ObjectProperty ;
                            rdfs:domain businessService:LogisticsService ;
                            rdfs:range <https://schema.org/Place> ;
                            rdfs:comment "Location of the logistics service" ;
                            rdfs:label "has location" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#hasRole
businessService:hasRole rdf:type owl:ObjectProperty ;
                        rdfs:domain businessService:LegalPerson ;
                        rdfs:range LogisticsRoles:ActorRoles ;
                        rdfs:comment "The relationship between legal person and LogisticsRoles:ActorRoles" ;
                        rdfs:label "has role" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#hasService
businessService:hasService rdf:type owl:ObjectProperty ;
                           rdfs:domain businessService:BusinessTransactionAAAA ;
                           rdfs:range businessService:LogisticsService ;
                           rdfs:comment "Business transaction is part of a logistics service" ;
                           rdfs:label "Has service" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#involvedActor
businessService:involvedActor rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf businessService:involves ;
                              rdfs:domain businessService:BusinessTransactionAAAA ;
                              rdfs:range businessService:LegalPerson ;
                              rdfs:comment "An Enterprise, Person or Organization can have different roles depending on the context. This property and its subproperties define the different roles that legal persons can play in the context of a business transaction." ;
                              rdfs:label "Involved actor" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#involvedAuthority
businessService:involvedAuthority rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf businessService:involvedCommercialActor ;
                                  rdfs:comment "The realtionship between a business transaction and an authority that has been instantiated as a businessService:legalperson." ;
                                  rdfs:label "involved authority" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#involvedBank
businessService:involvedBank rdf:type owl:ObjectProperty ;
                             rdfs:subPropertyOf businessService:involvedFinancialActor ;
                             rdfs:comment "The realtionship between a business transaction and a bank that has been instantiated as a businessService:legalperson." ;
                             rdfs:label "involved bank" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#involvedBusinessActor
businessService:involvedBusinessActor rdf:type owl:ObjectProperty ;
                                      rdfs:subPropertyOf businessService:involvedActor ;
                                      rdfs:comment "The realtionship between a business transaction and a business actor that has been instantiated as a businessService:legalperson." ;
                                      rdfs:label "involved business person" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#involvedCarrier
businessService:involvedCarrier rdf:type owl:ObjectProperty ;
                                rdfs:subPropertyOf businessService:involvedLogisticsActor ;
                                rdfs:comment "The realtionship between a business transaction and a carrier that has been instantiated as a businessService:legalperson." ;
                                rdfs:label "involved carrier" .


