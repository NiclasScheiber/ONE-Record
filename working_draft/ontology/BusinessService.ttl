                                          rdfs:label "involved warehouse operator" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#involves
businessService:involves rdf:type owl:ObjectProperty ;
                         rdfs:comment "Abstract property -- do not instantiate" ;
                         rdfs:label "Involves" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#partOfTransportMovementType
businessService:partOfTransportMovementType rdf:type owl:ObjectProperty ;
                                            rdfs:domain businessService:BusinessTransactionAAAA ;
                                            rdfs:range Classifications:TransportMovementType ;
                                            rdfs:comment "Describes if the business transaction if part of main-, on-, or precarriage" ;
                                            rdfs:label "Transport movement type" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#usedGoods
businessService:usedGoods rdf:type owl:ObjectProperty ;
                          rdfs:range DigitalTwin:Goods ;
                          rdfs:comment "Goods that are part of the logistics service" ;
                          rdfs:label "Used goods" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#usedPackage
businessService:usedPackage rdf:type owl:ObjectProperty ;
                            rdfs:range DigitalTwin:Package ;
                            rdfs:comment "Package that is part of the logistics service" ;
                            rdfs:label "Used package" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#usedPackagedProducts
businessService:usedPackagedProducts rdf:type owl:ObjectProperty ;
                                     rdfs:domain businessService:LogisticsService ;
                                     rdfs:comment "Packaged products that are part of the logistics service" ;
                                     rdfs:label "Package products" .


