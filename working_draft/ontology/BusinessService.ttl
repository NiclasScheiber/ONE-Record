                                        rdfs:range xsd:dateTime ;
                                        rdfs:comment "Time that Consigment is created" ;
                                        rdfs:label "consignment Creation Time" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#consignmentUpdateTime
businessService:consignmentUpdateTime rdf:type owl:DatatypeProperty ;
                                      rdfs:domain businessService:Consignment ;
                                      rdfs:range xsd:dateTime ;
                                      rdfs:comment "Time that Consigment is Updated" ;
                                      rdfs:label "consignment Update Time" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#createdBy
businessService:createdBy rdf:type owl:DatatypeProperty ;
                          rdfs:domain businessService:BusinessTransactionAAAA ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Creator of business transaction and its types for example booking" ;
                          rdfs:label "Created By" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#deviationDuration
businessService:deviationDuration rdf:type owl:DatatypeProperty ;
                                  rdfs:domain businessService:TransportService ;
                                  rdfs:range xsd:decimal ;
                                  rdfs:comment "Deviation on the duration of the transport service" ;
                                  rdfs:label "Deviation duration" .


