###  https://ontology.tno.nl/logistics/federated/BusinessService#actorID
businessService:actorID rdf:type owl:DatatypeProperty ;
                        rdfs:domain businessService:LegalPerson ;
                        rdfs:range xsd:string ;
                        rdfs:comment "ID of the logistics actor" ;
                        rdfs:label "Actor ID" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#actorName
businessService:actorName rdf:type owl:DatatypeProperty ;
                          rdfs:domain businessService:LegalPerson ;
                          rdfs:range xsd:string ;
                          rdfs:comment "Name of the logistics actor" ;
                          rdfs:label "Actor name" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#actorWebsite
businessService:actorWebsite rdf:type owl:DatatypeProperty ;
                             rdfs:domain businessService:LegalPerson ;
                             rdfs:range xsd:string ;
                             rdfs:comment "URL of the website of the logistics actor" ;
                             rdfs:label "Actor website" .


###  https://ontology.tno.nl/logistics/federated/BusinessService#bookingNumber
businessService:bookingNumber rdf:type owl:DatatypeProperty ;
                              rdfs:domain businessService:Booking ;
                              rdfs:range xsd:string ;
                              rdfs:comment "Booking number of the booking business transaction" ;
                              rdfs:label "Booking number" .


